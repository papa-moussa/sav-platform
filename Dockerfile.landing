# ──────────────────────────────────────────────────────────────────────────────
# sav-landing — Landing page (Nginx static)
# Pré-requis : cd sav-landing && ng build --configuration=production
# ──────────────────────────────────────────────────────────────────────────────
FROM nginx:alpine
COPY sav-landing/dist/sav-landing/browser /usr/share/nginx/html
COPY nginx/spa.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
