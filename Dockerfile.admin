# ──────────────────────────────────────────────────────────────────────────────
# sav-admin — Panel admin (Nginx static)
# Pré-requis : cd sav-admin && ng build --configuration=production
# Sortie : sav-admin/dist/sav-admin/browser/
# ──────────────────────────────────────────────────────────────────────────────
FROM nginx:alpine
COPY sav-admin/dist/sav-admin/browser /usr/share/nginx/html
COPY nginx/spa.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
