# ─── Base de données PostgreSQL ───────────────────────────────────────────────
# En Docker, l'hôte est le nom du service ("postgres"), pas "localhost"
DB_URL=jdbc:postgresql://postgres:5432/sav_db
DB_USER=sav_user
DB_PASSWORD=sav_pass

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
JWT_SECRET=aac97a96bb2edaff5db5aa8cfa9b8aa20261e1f0321cb17cf69048a754eea9a9

# ─── Profil Spring ────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ─── JPA DDL ──────────────────────────────────────────────────────────────────
# "update" pour la première mise en prod (crée les tables)
# Passer à "validate" une fois le schéma stable
DDL_AUTO=update

# ─── Mail (Gmail) ─────────────────────────────────────────────────────────────
# Utiliser un "App Password" Gmail (pas le mot de passe du compte)
# https://myaccount.google.com/apppasswords
MAIL_USERNAME=sn.dev.senior@gmail.com
MAIL_PASSWORD=wibwuoaxnbzzztkv
MAIL_FROM=sn.dev.senior@gmail.com


