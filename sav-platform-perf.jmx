  "description": "Ticket créé par JMeter thread ${__threadNum} iteration ${__jm__SAV - 100 Utilisateurs Simultanés__idx}",
  "priorite": "NORMAL",
  "clientId": ${clientId},
  "siteId": ${siteId},
  "appareil": "Appareil Test",
  "modele": "Modele Test JMeter",
  "numeroSerie": "SN-JMETER-${__threadNum}-${__Random(1000,9999)}"
}</stringProp>
