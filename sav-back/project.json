{
  "name": "sav-back",
  "projectType": "application",
  "root": "sav-back",
  "sourceRoot": "sav-back/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn clean package",
        "cwd": "sav-back"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn test",
        "cwd": "sav-back"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn spring-boot:run",
        "cwd": "sav-back"
      }
    }
  }
}
